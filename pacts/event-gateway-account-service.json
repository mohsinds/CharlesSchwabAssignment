{
  "consumer": {
    "name": "event-gateway"
  },
  "interactions": [
    {
      "description": "a request to apply a credit transaction",
      "providerStates": [
        {
          "name": "account acct-pact can accept transactions"
        }
      ],
      "request": {
        "body": {
          "amount": 25.5,
          "currency": "USD",
          "eventId": "evt-pact-1",
          "eventTimestamp": "2026-05-15T14:00:00Z",
          "type": "CREDIT"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
            },
            "$.currency": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.eventId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.eventTimestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/accounts/acct-pact/transactions"
      },
      "response": {
        "body": {
          "accountId": "acct-pact",
          "amount": 25.5,
          "appliedAt": "2026-05-15T14:05:00Z",
          "currency": "USD",
          "eventId": "evt-pact-1",
          "eventTimestamp": "2026-05-15T14:00:00Z",
          "type": "CREDIT"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.accountId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
            },
            "$.appliedAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": ".*"
                }
              ]
            },
            "$.currency": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.eventId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.eventTimestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": ".*"
                }
              ]
            },
            "$.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-jvm": {
      "version": "4.6.14"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "account-service"
  }
}
